<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>loading...</title>
</head>
<body>
<script>
const params = new URLSearchParams(window.location.search);

const id = params.get("id");
const imageLink = params.get("img");
const shopeeLink = params.get("shop");

if (!id || !imageLink || !shopeeLink) {
document.body.innerHTML = "參數錯誤";
} else {
const key = "visited_" + id;
const visited = localStorage.getItem(key);

if (!visited) {
localStorage.setItem(key, "1");
window.location.href = shopeeLink;
} else {
window.location.href = imageLink;
}
}
</script>
</body>
</html>
